<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <!-- VPN -->
    <uses-permission android:name="android.permission.BIND_VPN_SERVICE" />

    <!-- Foreground Services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!--
        FIX 1a: FOREGROUND_SERVICE_SPECIAL_USE kaldırıldı.
        BedrockRelayService ve OverlayService artık "dataSync" tipini kullanıyor.
        Android 14+ "specialUse" için Google Play onayı gerektirir ve sideload'da
        çökmeye yol açar. "dataSync" izni runtime'da ayrıca talep gerektirmez.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Overlay -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Wake Lock — paket işleme sırasında ekranın kapanmasını önler -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Android 11+ Paket Görünürlüğü -->
    <queries>
        <package android:name="com.mojang.minecraftpe" />
        <package android:name="com.netease.mc" />
        <package android:name="com.mojang.minecrafttrialpe" />
    </queries>

    <application
        android:name=".OxClientApp"
        android:allowBackup="false"
        android:icon="@drawable/ic_ox_logo"
        android:label="OxClient"
        android:roundIcon="@drawable/ic_ox_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.OxClient"
        android:usesCleartextTraffic="true"
        tools:targetApi="35">

        <!-- Ana Dashboard -->
        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Microsoft Auth -->
        <activity
            android:name=".auth.DeviceCodeLoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- VPN Servisi — specialUse burada mantıklı, VPN izni zaten örtük onay sayılır -->
        <service
            android:name=".core.vpn.OxVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="VPN_tunnel_for_Minecraft_Bedrock_proxy" />
        </service>

        <!--
            FIX 1b: BedrockRelayService foregroundServiceType="specialUse" → "dataSync"
            "specialUse" Android 14'te FOREGROUND_SERVICE_SPECIAL_USE iznini zorunlu kılar
            ve Play dışı dağıtımda SecurityException fırlatır. "dataSync" bu kısıtlamadan muaftır.
        -->
        <service
            android:name=".proxy.BedrockRelayService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!--
            FIX 1c: OverlayService foregroundServiceType="specialUse" → "dataSync"
            Aynı sebep; ayrıca overlay izni zaten SYSTEM_ALERT_WINDOW ile yönetilir.
        -->
        <service
            android:name=".ui.overlay.OverlayService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>
</manifest>
